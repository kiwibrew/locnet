{
  "name": "locnet-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:watch": "vite build --minify false --mode development --watch",
    "preview": "vite preview",
    "test": "npm run test:unittest && npm run test:types && npm run test:lint",
    "test:unittest": "vitest run",
    "test:types": "tsc -b",
    "test:lint": "eslint .",
    "format:prettier": "npx prettier --write .",
    "generate:api": "npx apigen-ts --no http://localhost:8000/openapi.json ./src/features/locnet/api-generated-client.ts && npx ts-to-zod ./src/features/locnet/api-generated-client.ts ./src/features/locnet/api-generated-zod.ts --skipValidation"
  },
  "dependencies": {
    "@noble/hashes": "2.0.1",
    "@redux-devtools/extension": "4.0.0",
    "@tanstack/react-table": "8.21.3",
    "@vanillaes/csv": "3.0.4",
    "canvg": "4.0.3",
    "dompdf.js": "1.1.1",
    "dompurify": "3.3.3",
    "immer": "11.0.0",
    "lodash-es": "4.18.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-icons": "5.5.0",
    "recharts": "3.7.0",
    "write-excel-file": "2.3.10",
    "zod": "4.1.12",
    "zustand": "5.0.8"
  },
  "devDependencies": {
    "@eslint/js": "9.39.1",
    "@types/lodash-es": "4.17.12",
    "@types/node": "24.10.0",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@vitejs/plugin-react-swc": "4.2.1",
    "apigen-ts": "1.3.0",
    "eslint": "9.39.1",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.4.24",
    "ts-to-zod": "5.1.0",
    "typescript-eslint": "8.46.3",
    "vite": "7.2.2",
    "vitest": "4.0.13"
  },
  "peerDependencies": {
    "typescript": "5.9.3"
  }
}
